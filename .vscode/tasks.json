{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Aicomic Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Auto Sync to GitHub",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"auto-sync"
			],
			"isBackground": true
		},
		{
			"label": "Auto Sync Once (Dry Run)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"auto-sync:once"
			]
		},
		{
			"label": "Auto Sync to GitHub",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"auto-sync"
			],
			"isBackground": true
		}
	]
}